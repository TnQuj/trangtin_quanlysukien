<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bảng điều khiển - Admin iEvent</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Inter', system-ui, sans-serif;
        }

        .stat-card {
            border: none;
            border-radius: 16px;
            transition: all 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
        }

        .icon-shape {
            width: 48px;
            height: 48px;
            background-position: center;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .bg-gradient-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .bg-gradient-success {
            background: linear-gradient(135deg, #2dce89 0%, #2dcecc 100%);
        }

        .bg-gradient-info {
            background: linear-gradient(135deg, #11cdef 0%, #1171ef 100%);
        }

        .bg-gradient-warning {
            background: linear-gradient(135deg, #fb6340 0%, #fbb140 100%);
        }

        .card-title-custom {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #8898aa;
        }

        .project-signature {
            font-size: 0.9rem;
            color: #525f7f;
            border-left: 3px solid #5e72e4;
            padding-left: 15px;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <%- include('partials/navbar') %>

        <div class="flex-grow-1 p-4">
            <div class="container-fluid">

                <div class="row mb-4 align-items-center">
                    <div class="col">
                        <h2 class="fw-bold text-dark mb-1">Chào mừng trở lại, <%= hoVaTen %>! 👋</h2>
                        <p class="text-muted">Hôm nay là <%= new Date().toLocaleDateString('vi-VN', { weekday: 'long' ,
                                year: 'numeric' , month: 'long' , day: 'numeric' }) %>
                        </p>
                    </div>
                    <div class="col-auto">
                        <div class="project-signature">
                            <strong>Đồ án Điện toán Đám mây</strong><br>
                            SV thực hiện: <span class="text-primary">Nhật Minh & Ngọc Quí</span>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card shadow-sm">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h5 class="card-title-custom mb-1">Tổng Sự Kiện</h5>
                                        <span class="h2 fw-bold mb-0">
                                            <%= tongSuKien %>
                                        </span>
                                    </div>
                                    <div class="icon-shape bg-gradient-primary text-white shadow">
                                        <i class="bi bi-calendar-check fs-4"></i>
                                    </div>
                                </div>
                                <p class="mt-3 mb-0 text-sm">
                                    <span class="text-success me-2"><i class="bi bi-arrow-up"></i>
                                        <%= suKienSapToi %>
                                    </span>
                                    <span class="text-nowrap text-muted">Sự kiện sắp tới</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card shadow-sm">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h5 class="card-title-custom mb-1">Lượt Đăng Ký</h5>
                                        <span class="h2 fw-bold mb-0">
                                            <%= tongDangKy %>
                                        </span>
                                    </div>
                                    <div class="icon-shape bg-gradient-success text-white shadow">
                                        <i class="bi bi-people fs-4"></i>
                                    </div>
                                </div>
                                <p class="mt-3 mb-0 text-sm">
                                    <span class="text-info me-2"><i class="bi bi-person-check"></i> Hoạt động</span>
                                    <span class="text-nowrap text-muted">Trên toàn hệ thống</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card shadow-sm">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h5 class="card-title-custom mb-1">Thành Viên</h5>
                                        <span class="h2 fw-bold mb-0">
                                            <%= tongTaiKhoan %>
                                        </span>
                                    </div>
                                    <div class="icon-shape bg-gradient-info text-white shadow">
                                        <i class="bi bi-person-circle fs-4"></i>
                                    </div>
                                </div>
                                <p class="mt-3 mb-0 text-sm">
                                    <span class="text-warning me-2"><i class="bi bi-shield-lock"></i> Bảo mật</span>
                                    <span class="text-nowrap text-muted">Đã xác thực</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card shadow-sm">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h5 class="card-title-custom mb-1">Hoàn Thành</h5>
                                        <span class="h2 fw-bold mb-0">
                                            <%= suKienDaKetThuc %>
                                        </span>
                                    </div>
                                    <div class="icon-shape bg-gradient-warning text-white shadow">
                                        <i class="bi bi-trophy fs-4"></i>
                                    </div>
                                </div>
                                <p class="mt-3 mb-0 text-sm">
                                    <span class="text-muted">Sự kiện đã diễn ra xong</span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-transparent border-0 pt-4 px-4">
                                <h5 class="fw-bold text-dark mb-0"><i class="bi bi-graph-up me-2"></i>Tình hình tham gia
                                </h5>
                            </div>
                            <div class="card-body p-4">

                                <div class="text-center py-5">
                                    <i class="bi bi-bar-chart-line text-light" style="font-size: 100px;"></i>
                                    <p class="text-muted">Tính năng biểu đồ trực quan Chart.js đang được tích hợp...</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-transparent border-0 pt-4 px-4">
                                <h5 class="fw-bold text-dark mb-0"><i class="bi bi-lightning-charge me-2"></i>Thao tác
                                    nhanh</h5>
                            </div>
                            <div class="card-body p-4">
                                <div class="list-group list-group-flush">
                                    <a href="/them"
                                        class="list-group-item list-group-item-action border-0 rounded-3 mb-2 p-3 bg-light">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-plus-circle-fill text-primary fs-4 me-3"></i>
                                            <div>
                                                <h6 class="mb-0 fw-bold">Tạo sự kiện mới</h6>
                                                <small class="text-muted">Đăng tải thông tin lên trang chủ</small>
                                            </div>
                                        </div>
                                    </a>
                                    <a href="/admin/taikhoan"
                                        class="list-group-item list-group-item-action border-0 rounded-3 mb-2 p-3 bg-light">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-shield-check text-success fs-4 me-3"></i>
                                            <div>
                                                <h6 class="mb-0 fw-bold">Phê duyệt tài khoản</h6>
                                                <small class="text-muted">Quản lý quyền sinh viên</small>
                                            </div>
                                        </div>
                                    </a>
                                    <a href="/admin/danhsachdangky"
                                        class="list-group-item list-group-item-action border-0 rounded-3 p-3 bg-light">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-file-earmark-spreadsheet text-warning fs-4 me-3"></i>
                                            <div>
                                                <h6 class="mb-0 fw-bold">Xuất danh sách đăng ký</h6>
                                                <small class="text-muted">Kiểm tra lượt đăng ký theo sự kiện</small>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <%- include('partials/footer') %>

</body>

</html>