<!DOCTYPE html>
<html>

<head>
    <title>Danh sách đăng ký</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="d-flex flex-column min-vh-100">

    <%- include('partials/navbar') %>

        <div class="flex-grow-1 p-4">
            <h2 class="mb-4">📋 Danh sách đăng ký theo sự kiện</h2>

            <% if (danhSachSuKien.length===0) { %>
                <div class="alert alert-info">Chưa có ai đăng ký sự kiện nào.</div>
                <% } else { %>
                    <div class="row">
                        <% danhSachSuKien.forEach(item=> { %>
                            <div class="col-md-6 mb-4">
                                <div class="card shadow h-100">
                                    <div class="card-body">
                                        <h5 class="card-title">
                                            <%= item.suKien.tenSuKien %>
                                        </h5>

                                        <p class="card-text mb-1">
                                            📍 <%= item.suKien.diaDiem %><br>
                                                📅 <%= new Date(item.suKien.ngay).toLocaleDateString('vi-VN') %>
                                        </p>

                                        <!-- MÔ TẢ SỰ KIỆN -->
                                        <p class="card-text text-muted">
                                            <%= item.suKien.moTa || 'Không có mô tả' %>
                                        </p>

                                        <div class="d-flex justify-content-between align-items-center mt-3">
                                            <span class="badge bg-primary fs-6">
                                                👥 <%= item.soLuong %> người đăng ký
                                            </span>

                                            <a href="/admin/sukien_dangky/<%= item.suKien._id %>" class="btn btn-info">
                                                Xem danh sách người tham gia
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } %>
        </div>

        <%- include('partials/footer') %>

</body>

</html>