<!DOCTYPE html>
<html>

<head>
    <title>Sự kiện đã đăng ký</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="d-flex flex-column min-vh-100">

    <%- include('partials/navbar') %>

        <div class="flex-grow-1 p-4">
            <h2 class="mb-4">Các sự kiện bạn đã đăng ký</h2>

            <% if (danhSach.length===0) { %>
                <div class="alert alert-info">
                    Bạn chưa đăng ký tham gia sự kiện nào.
                </div>
                <% } else { %>
                    <div class="row">
                        <% danhSach.forEach(item=> { %>
                            <div class="col-md-6 mb-4">
                                <div class="card shadow h-100">
                                    <div class="card-body">
                                        <h5 class="card-title">
                                            <%= item.suKien.tenSuKien %>
                                        </h5>
                                        <p class="card-text">
                                            📍 <%= item.suKien.diaDiem %><br>
                                                📅 <%= new Date(item.suKien.ngay).toLocaleDateString('vi-VN') %>
                                        </p>
                                        <p class="card-text text-muted">
                                            <%= item.suKien.moTa || 'Không có mô tả' %>
                                        </p>
                                        <small class="text-muted">
                                            Đăng ký ngày: <%= new Date(item.ngayDangKy).toLocaleDateString('vi-VN') %>
                                        </small>

                                        <!-- Chỉ giữ nút Hủy đăng ký -->
                                        <div class="mt-3">
                                            <form action="/huy_dangky/<%= item._id %>" method="POST" class="d-inline">
                                                <button type="submit"
                                                    onclick="return confirm('Bạn có chắc muốn hủy đăng ký sự kiện này?')"
                                                    class="btn btn-danger btn-sm">
                                                    ❌ Hủy đăng ký
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } %>
        </div>

        <%- include('partials/footer') %>

</body>

</html>