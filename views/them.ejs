<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thêm sự kiện mới - iEvent</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #3f37c9;
            --bg-body: #f8f9fa;
        }

        body {
            background-color: var(--bg-body);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .main-card {
            border: none;
            border-radius: 24px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            overflow: hidden;
        }

        .header-gradient {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            padding: 40px 20px;
            color: white;
            text-align: center;
        }

        .form-label {
            font-weight: 600;
            color: #495057;
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .input-group-text {
            background-color: #fff;
            border-right: none;
            color: #adb5bd;
        }

        .form-control {
            border-left: none;
            padding: 12px;
            border-radius: 0 10px 10px 0;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #dee2e6;
        }

        .input-group:focus-within .input-group-text,
        .input-group:focus-within .form-control {
            border-color: var(--primary-color);
            color: var(--primary-color);
        }

        .btn-save {
            background-color: var(--primary-color);
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            transition: all 0.3s;
        }

        .btn-save:hover {
            background-color: var(--secondary-color);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(67, 97, 238, 0.3);
        }

        .preview-box {
            border: 2px dashed #dee2e6;
            border-radius: 15px;
            padding: 10px;
            background: #fff;
            text-align: center;
        }

        #imagePreviewThem {
            max-width: 100%;
            border-radius: 10px;
            display: block;
            margin: 0 auto;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <%- include('partials/navbar') %>

        <main class="flex-grow-1 py-5">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-xl-7">

                        <div class="main-card card">
                            <div class="header-gradient">
                                <i class="bi bi-calendar-plus fs-1 mb-2"></i>
                                <h2 class="fw-bold mb-0">Tạo Sự Kiện Mới</h2>
                                <p class="opacity-75 mb-0">Chia sẻ những khoảnh khắc ý nghĩa đến mọi người</p>
                            </div>

                            <div class="card-body p-4 p-md-5">
                                <form action="/them" method="POST">

                                    <div class="mb-4">
                                        <label class="form-label"><i class="bi bi-tag me-2"></i>Tên sự kiện</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-pencil"></i></span>
                                            <input type="text" name="tenSuKien" class="form-control"
                                                placeholder="VD: Hội thảo công nghệ 2026..." required autofocus>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-4">
                                            <label class="form-label"><i class="bi bi-calendar-event me-2"></i>Ngày tổ
                                                chức</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                                                <input type="date" name="ngay" class="form-control"
                                                    style="border-left: none;" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6 mb-4">
                                            <label class="form-label"><i class="bi bi-geo-alt me-2"></i>Địa điểm</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-pin-map"></i></span>
                                                <input type="text" name="diaDiem" class="form-control"
                                                    placeholder="Hội trường A, Nhà thi đấu..." required>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label"><i class="bi bi-image me-2"></i>Link hình ảnh
                                            Banner</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-link-45deg"></i></span>
                                            <input type="url" name="hinhAnh" id="inputHinhAnh" class="form-control"
                                                placeholder="https://example.com/image.jpg"
                                                oninput="previewImageThem()">
                                        </div>
                                        <div class="mt-3 d-none" id="previewContainerThem">
                                            <div class="preview-box">
                                                <img src="" id="imagePreviewThem" alt="Preview"
                                                    onerror="handleImageErrorThem()">
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label"><i class="bi bi-chat-left-text me-2"></i>Mô tả chi
                                            tiết</label>
                                        <textarea name="moTa" class="form-control" rows="5"
                                            placeholder="Viết vài dòng giới thiệu về sự kiện..."
                                            style="border-left: 1px solid #ced4da; border-radius: 10px;"></textarea>
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-sm-8">
                                            <button type="submit" class="btn btn-save btn-primary w-100 text-white">
                                                <i class="bi bi-check2-circle me-2"></i>Phát hành sự kiện
                                            </button>
                                        </div>
                                        <div class="col-sm-4">
                                            <a href="/sukien" class="btn btn-outline-secondary w-100 py-3 fw-bold"
                                                style="border-radius: 12px;">Hủy bỏ</a>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function previewImageThem() {
                    const urlInput = document.getElementById('inputHinhAnh').value.trim();
                    const previewContainer = document.getElementById('previewContainerThem');
                    const imagePreview = document.getElementById('imagePreviewThem');

                    if (urlInput !== "") {
                        imagePreview.src = urlInput;
                        previewContainer.classList.remove('d-none');
                    } else {
                        previewContainer.classList.add('d-none');
                    }
                }

                function handleImageErrorThem() {
                    const previewContainer = document.getElementById('previewContainerThem');
                    previewContainer.classList.add('d-none');
                    // Gợi ý cho người dùng thay vì dùng alert gây khó chịu
                    console.log("Link ảnh không hiển thị được.");
                }
            </script>
</body>

</html>