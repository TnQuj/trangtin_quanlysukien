<!DOCTYPE html>
<html>

<head>
    <title>Sửa sự kiện</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- NAVBAR -->
    <%- include('partials/navbar') %>

        <!-- NỘI DUNG CHÍNH -->
        <div class="flex-grow-1">
            <div class="container mt-4">
                <h2 class="text-warning mb-4">✏️ Sửa sự kiện</h2>

                <form action="/sua/<%= event._id %>" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên sự kiện</label>
                        <input type="text" name="tenSuKien" class="form-control" value="<%= event.tenSuKien %>"
                            required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Ngày tổ chức</label>
                            <input type="date" name="ngay" class="form-control"
                                value="<%= event.ngay.toISOString().split('T')[0] %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Địa điểm</label>
                            <input type="text" name="diaDiem" class="form-control" value="<%= event.diaDiem %>"
                                required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Link Hình ảnh (Tùy chọn)</label>
                        <input type="url" name="hinhAnh" class="form-control"
                            placeholder="Nhập đường dẫn ảnh (Ví dụ: https://...)" value="<%= event.hinhAnh || '' %>">
                        <small class="text-muted">Bạn có thể copy link ảnh từ Facebook, Google Drive hoặc các trang web
                            khác dán vào đây.</small>
                    </div>

                    <% if (event.hinhAnh) { %>
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary small">Ảnh hiện tại:</label>
                            <div class="border rounded p-2 bg-light d-inline-block">
                                <img src="<%= event.hinhAnh %>" alt="Preview" class="img-fluid rounded"
                                    style="max-height: 150px; object-fit: cover;">
                            </div>
                        </div>
                        <% } %>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Mô tả chi tiết</label>
                                <textarea name="moTa" class="form-control" rows="4"><%= event.moTa %></textarea>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success fw-bold px-4"><i
                                        class="bi bi-save2 me-1"></i> Lưu thay đổi</button>
                                <a href="/sukien" class="btn btn-secondary fw-bold px-4">Quay lại</a>
                            </div>
                </form>
            </div>
        </div>

        <!-- FOOTER -->
        <footer class="bg-dark text-white py-4 mt-auto">
            <div class="container text-center">
                <p class="mb-0">
                    Bản quyền © 2026 bởi
                    <strong>Phan Nhật Minh - Thái Ngọc Quí</strong>
                </p>
                <p class="mb-0 small text-white">
                    Website Quản lý Sự kiện - Đồ án Điện toán Đám mây
                </p>
            </div>
        </footer>

</body>

</html>