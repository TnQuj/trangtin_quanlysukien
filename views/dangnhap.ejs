<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - iEvent</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            overflow-x: hidden;
        }

        .login-container {
            min-height: 100vh;
        }

        /* --- CỘT TRÁI: HÌNH ẢNH BANNER --- */
        .login-sidebar {
            /* Hình nền lấy từ Unsplash có phủ một lớp gradient xanh mờ */
            background: linear-gradient(135deg, rgba(0, 123, 255, 0.85), rgba(0, 198, 255, 0.85)), url('https://images.unsplash.com/photo-1540575467063-178a50c2df87?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80') no-repeat center center;
            background-size: cover;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
            position: relative;
        }

        .login-sidebar h1 {
            font-weight: 800;
            font-size: 3.5rem;
            text-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            margin-bottom: 10px;
        }

        .login-sidebar p {
            font-size: 1.1rem;
            opacity: 0.9;
            text-align: center;
            max-width: 450px;
            line-height: 1.6;
        }

        /* --- CỘT PHẢI: KHU VỰC FORM --- */
        .login-form-area {
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 40px;
            background-color: #ffffff;
        }

        .login-form-wrapper {
            max-width: 420px;
            width: 100%;
            margin: 0 auto;
        }

        .form-control-custom {
            padding: 12px 15px;
            border: 1px solid #dee2e6;
            background-color: #f8f9fa;
            box-shadow: none !important;
        }

        .form-control-custom:focus {
            background-color: #ffffff;
            border-color: #007BFF;
        }

        /* Chỉnh lại viền khi focus ô input có icon */
        .input-group:focus-within .input-group-text,
        .input-group:focus-within .form-control-custom {
            border-color: #007BFF;
            background-color: #ffffff;
        }

        .input-group-text {
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            transition: all 0.3s ease;
        }

        .btn-primary-custom {
            background-color: #007BFF;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-weight: bold;
            letter-spacing: 0.5px;
            transition: all 0.3s;
        }

        .btn-primary-custom:hover {
            background-color: #0056b3;
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(0, 123, 255, 0.2);
        }

        /* Logo chỉ hiện trên di động */
        .brand-mobile {
            display: none;
            color: #007BFF;
            font-weight: 800;
            font-size: 2.5rem;
            text-align: center;
            margin-bottom: 25px;
        }

        /* Responsive: Ẩn cột hình ảnh khi dùng điện thoại */
        @media (max-width: 991.98px) {
            .login-sidebar {
                display: none !important;
            }

            .brand-mobile {
                display: block;
            }

            .login-form-area {
                padding: 20px;
            }
        }
    </style>
</head>

<body>
    <div class="row g-0 login-container">

        <div class="col-lg-6 login-sidebar d-none d-lg-flex">
            <h1>⭐ iEvents</h1>
            <p class="mt-3">Nền tảng quản lý và theo dõi sự kiện nội bộ chuyên nghiệp, giúp bạn không bỏ lỡ bất kỳ hoạt
                động nào.</p>
        </div>

        <div class="col-lg-6 login-form-area">
            <div class="login-form-wrapper">

                <div class="brand-mobile">⭐ iEvents</div>

                <div class="mb-4">
                    <h3 class="fw-bold text-dark mb-1">Đăng nhập</h3>
                    <p class="text-muted small">Nhập tên tài khoản và mật khẩu để tiếp tục</p>
                </div>

                <% if (typeof success !=='undefined' && success) { %>
                    <div class="alert alert-success border-0 shadow-sm py-2" id="autoAlert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <%= success %>
                    </div>
                    <% } %>
                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="alert alert-danger border-0 shadow-sm py-2" id="autoAlert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <form action="/dangnhap" method="POST">
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold text-secondary small">Nhập MSSV</label>
                                        <div class="input-group">
                                            <span class="input-group-text border-end-0 rounded-start-3"><i
                                                    class="bi bi-person text-muted"></i></span>
                                            <input type="text" name="tenDangNhap"
                                                class="form-control form-control-custom border-start-0 rounded-end-3 ps-0"
                                                placeholder="Ví dụ: DPM123456" required autofocus>
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        <label class="form-label fw-semibold text-secondary small">Mật khẩu</label>
                                        <div class="input-group">
                                            <span class="input-group-text border-end-0 rounded-start-3"><i
                                                    class="bi bi-lock text-muted"></i></span>
                                            <input type="password" name="matKhau"
                                                class="form-control form-control-custom border-start-0 rounded-end-3 ps-0"
                                                placeholder="••••••••" required>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="rememberMe">
                                            <label class="form-check-label small text-muted" for="rememberMe"
                                                style="cursor: pointer;">Ghi nhớ đăng nhập</label>
                                        </div>
                                        <a href="#" class="text-decoration-none small fw-semibold"
                                            style="color: #007BFF;">Quên mật khẩu?</a>
                                    </div>

                                    <button type="submit" class="btn btn-primary-custom w-100 fs-6">Đăng nhập vào hệ
                                        thống</button>
                                </form>

                                <div class="text-center mt-4 pt-3 border-top">
                                    <p class="text-muted small mb-0">Chưa có tài khoản? <a href="/dangky"
                                            class="text-decoration-none fw-bold ms-1" style="color: #007BFF;">Đăng ký
                                            ngay</a></p>
                                </div>
            </div>
        </div>

    </div>

    <script>
        setTimeout(() => {
            const alerts = document.querySelectorAll('#autoAlert');
            alerts.forEach(alert => {
                alert.style.transition = 'opacity 0.5s ease';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            });
        }, 3000);
    </script>
</body>

</html>