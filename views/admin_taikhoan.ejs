<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Tài khoản - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Roboto, sans-serif;
        }

        .table-custom th {
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            color: #6c757d;
        }

        .avatar-img {
            width: 45px;
            height: 45px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid #e9ecef;
        }

        .action-btn {
            transition: all 0.2s;
        }

        .action-btn:hover {
            transform: scale(1.1);
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <%- include('partials/navbar') %>

        <div class="flex-grow-1 p-4">
            <div class="container-fluid bg-white rounded-4 shadow-sm p-4">

                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                    <h4 class="fw-bold text-dark mb-0">
                        <i class="bi bi-people-fill me-2 text-primary"></i>Quản lý Tài Khoản
                    </h4>
                    <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">Tổng số: <%= users.length %> tài
                            khoản</span>
                </div>

                <% if (success) { %>
                    <div id="autoAlert" class="alert alert-success py-2 border-0 shadow-sm"><i
                            class="bi bi-check-circle-fill me-2"></i>
                        <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div id="autoAlert" class="alert alert-danger py-2 border-0 shadow-sm"><i
                                    class="bi bi-exclamation-triangle-fill me-2"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <div class="table-responsive">
                                    <table class="table table-hover align-middle table-custom">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Người dùng</th>
                                                <th>Tên Đăng Nhập</th>
                                                <th>Vai trò</th>
                                                <th>Trạng thái</th>
                                                <th>Ngày tham gia</th>
                                                <th class="text-end">Hành động</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% users.forEach(user=> { %>
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.hoVaTen) %>&background=random&color=fff&size=100"
                                                                class="avatar-img me-3" alt="Avatar">
                                                            <div>
                                                                <div class="fw-bold text-dark">
                                                                    <%= user.hoVaTen %>
                                                                </div>
                                                                <div class="text-muted small">
                                                                    <%= user.email || 'Chưa cập nhật email' %>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </td>

                                                    <td>
                                                        <span class="text-secondary fw-medium">
                                                            <%= user.tenDangNhap %>
                                                        </span>
                                                    </td>

                                                    <td>
                                                        <% if (user.role==='admin' ) { %>
                                                            <span
                                                                class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1"><i
                                                                    class="bi bi-shield-lock-fill me-1"></i> Quản trị
                                                                viên</span>
                                                            <% } else { %>
                                                                <span
                                                                    class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-2 py-1"><i
                                                                        class="bi bi-person-fill me-1"></i> Sinh
                                                                    viên</span>
                                                                <% } %>
                                                    </td>

                                                    <td>
                                                        <% if (user.khoa===true) { %>
                                                            <span class="badge bg-secondary px-2 py-1"><i
                                                                    class="bi bi-lock-fill me-1"></i> Đã khóa</span>
                                                            <% } else { %>
                                                                <span class="badge bg-success px-2 py-1"><i
                                                                        class="bi bi-check-circle-fill me-1"></i> Hoạt
                                                                    động</span>
                                                                <% } %>
                                                    </td>

                                                    <td class="text-muted small">
                                                        <%= new Date(user.ngayTao).toLocaleDateString('vi-VN') %>
                                                    </td>

                                                    <td class="text-end">
                                                        <button type="button"
                                                            class="btn btn-light btn-sm text-primary border action-btn me-1"
                                                            title="Cấp quyền" data-bs-toggle="modal"
                                                            data-bs-target="#suaQuyenModal<%= user._id %>">
                                                            <i class="bi bi-person-gear"></i>
                                                        </button>

                                                        <% if (user.khoa===true) { %>
                                                            <form action="/admin/khoataikhoan/<%= user._id %>"
                                                                method="POST" class="d-inline">
                                                                <button type="submit"
                                                                    onclick="return confirm('Mở khóa cho tài khoản này?')"
                                                                    class="btn btn-light btn-sm text-success border action-btn"
                                                                    title="Mở khóa">
                                                                    <i class="bi bi-unlock-fill"></i>
                                                                </button>
                                                            </form>
                                                            <% } else { %>
                                                                <form action="/admin/khoataikhoan/<%= user._id %>"
                                                                    method="POST" class="d-inline">
                                                                    <button type="submit"
                                                                        onclick="return confirm('Khóa tài khoản này? Người dùng sẽ không thể đăng nhập.')"
                                                                        class="btn btn-light btn-sm text-danger border action-btn"
                                                                        title="Khóa tài khoản">
                                                                        <i class="bi bi-lock-fill"></i>
                                                                    </button>
                                                                </form>
                                                                <% } %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>

            </div>
        </div>

        <%- include('partials/footer') %>

            <% users.forEach(user=> { %>
                <div class="modal fade" id="suaQuyenModal<%= user._id %>" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-0 shadow">
                            <div class="modal-header bg-light">
                                <h5 class="modal-title fw-bold text-primary"><i
                                        class="bi bi-shield-shaded me-2"></i>Phân quyền tài khoản</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4">
                                <form action="/admin/suarole/<%= user._id %>" method="POST">

                                    <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-3 border">
                                        <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.hoVaTen) %>&background=random"
                                            class="rounded-circle me-3" style="width: 50px;">
                                        <div>
                                            <h6 class="mb-0 fw-bold">
                                                <%= user.hoVaTen %>
                                            </h6>
                                            <small class="text-muted">Username: <%= user.tenDangNhap %></small>
                                        </div>
                                    </div>

                                    <label class="form-label fw-semibold">Vai trò của người dùng này:</label>
                                    <select name="role" class="form-select form-select-lg mb-4">
                                        <option value="user" <%=user.role==='user' ? 'selected' : '' %>>Sinh viên (Thành
                                            viên thường)</option>
                                        <option value="admin" <%=user.role==='admin' ? 'selected' : '' %>>Quản trị viên
                                            (Admin)</option>
                                    </select>

                                    <div class="d-grid gap-2">
                                        <button type="submit" class="btn btn-primary fw-bold py-2">Lưu thay đổi</button>
                                        <button type="button" class="btn btn-light border py-2"
                                            data-bs-dismiss="modal">Hủy bỏ</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>

                    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                    <script>
                        // Tự động ẩn thông báo
                        setTimeout(() => {
                            const alerts = document.querySelectorAll('#autoAlert');
                            alerts.forEach(a => { a.style.opacity = '0'; setTimeout(() => a.remove(), 500); });
                        }, 3000);
                    </script>
</body>

</html>