<!DOCTYPE html>
<html>
<head>
    <title>Người tham gia - <%= suKien.tenSuKien %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">

    <%- include('partials/navbar') %>

    <div class="flex-grow-1 container mt-4">
        <a href="/admin/danhsachdangky" class="btn btn-secondary mb-3">← Quay lại Danh sách đăng ký</a>
        
        <h2 class="mb-4">
            👥 Người tham gia: <span class="text-primary"><%= suKien.tenSuKien %></span>
        </h2>

        <% if (danhSachDangKy.length === 0) { %>
            <div class="alert alert-info">Chưa có ai đăng ký sự kiện này.</div>
        <% } else { %>
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Họ và tên</th>
                        <th>Tên đăng nhập</th>
                        <th>Email</th>
                        <th>Ngày đăng ký</th>
                    </tr>
                </thead>
                <tbody>
                    <% danhSachDangKy.forEach(dk => { %>
                    <tr>
                        <td><%= dk.taiKhoan.hoVaTen %></td>
                        <td><%= dk.taiKhoan.tenDangNhap %></td>
                        <td><%= dk.taiKhoan.email %></td>
                        <td><%= new Date(dk.ngayDangKy).toLocaleDateString('vi-VN') %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>

    <%- include('partials/footer') %>

</body>
</html>